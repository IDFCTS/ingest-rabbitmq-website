# Stage 2: Serve with Nginx
FROM nginxinc/nginx-unprivileged:alpine
# Copy the built site from the builder stage
COPY /build/ /usr/share/nginx/html

# Use a dedicated unprivileged NGINX config for deep links and port-agnostic redirects.
COPY infrastructure/nginx/unprivileged-default.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]